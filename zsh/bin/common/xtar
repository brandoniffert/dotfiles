#!/usr/bin/env bash

set -e

if [ $# -ne 1 ]; then
  echo "! Too few args"
  exit 1
fi

case "$1" in
  *.tar.zst|*.tzst)
    DECOMP="zstd -dc -T0"
    ;;
  *.tar.gz|*.tgz)
    DECOMP="pigz -dc"
    ;;
  *)
    echo "! Unknown format: $1"
    exit 1
    ;;
esac

TAR=tar
command -v gtar &> /dev/null && TAR=gtar

$DECOMP "$1" | pv | $TAR xf -
